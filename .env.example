# Default safety flags. Keep these safe unless a later ticket explicitly changes mode handling.
DRY_RUN=true
LIVE_TRADING_ENABLED=false
AUTO_TRADE_ENABLED=false
SIGNAL_ONLY=false
PAPER_TRADING=false
SEMI_AUTO_ENABLED=false

# Runtime
NODE_ENV=development
LOG_LEVEL=info

# Database placeholder for B0 foundation.
DATABASE_URL=memory://local

# Providers
AI_PROVIDER=openrouter
AI_FALLBACK_MODE=rule_based
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
EXCHANGE_NAME=mexc
MEXC_BASE_URL=https://api.mexc.fm

# Secrets are intentionally blank in example files.
OPENROUTER_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
MEXC_API_KEY=
MEXC_API_SECRET=
